# ── Wallet ──────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ──────────────────────────────────────────────────────────────────
# Get a free API key at https://www.helius.dev/
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# ── LLM Provider ────────────────────────────────────────────────────────────────
# Option A: OpenRouter (default)
# OPENROUTER_API_KEY=sk-or-v1-...
#
# Option B: LM Studio (local) — uncomment these and comment out OPENROUTER_API_KEY
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=your-model-here

# ── API Keys ─────────────────────────────────────────────────────────────────────
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
LPAGENT_API_KEY=your_lpagent_api_key_here

# ── Telegram Notifications (optional) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
TELEGRAM_ALLOWED_USER_IDS=123456789

# ── Dangerous admin actions (disabled by default) ────────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ─────────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
